{
    "name": "flowtriq/pterodactyl-addon",
    "description": "DDoS detection and service port protection for Pterodactyl Panel via Flowtriq",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Flowtriq\\Pterodactyl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flowtriq\\Pterodactyl\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Flowtriq\\Pterodactyl\\FlowtriqServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
